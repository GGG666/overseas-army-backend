<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.overseas.army.mapper.UniversityMapper">
    <resultMap id="BaseResultMap" type="com.overseas.army.entity.University">
        <id column="id" property="id"/>
        <result column="name_cn" property="nameCn"/>
        <result column="name_en" property="nameEn"/>
        <result column="country" property="country"/>
        <result column="rank" property="rank"/>
        <result column="logo_url" property="logoUrl"/>
        <result column="location" property="location"/>
        <result column="website" property="website"/>
        <result column="background_image" property="backgroundImage"/>
        <result column="school_type" property="schoolType"/>
        <result column="establish_year" property="establishYear"/>
        <result column="student_num" property="studentNum"/>
        <result column="international_ratio" property="internationalRatio"/>
        <result column="description" property="description"/>
        <result column="admission_requirement" property="admissionRequirement"/>
        <result column="tuition_range" property="tuitionRange"/>
        <result column="scholarship_desc" property="scholarshipDesc"/>
        <result column="famous_alumni" property="famousAlumni"/>
        <result column="ranking_info" property="rankingInfo"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM university ORDER BY rank ASC
    </select>

    <select id="findByCountry" resultMap="BaseResultMap">
        SELECT * FROM university WHERE country = #{country} ORDER BY rank ASC
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM university WHERE id = #{id}
    </select>

    <select id="search" resultMap="BaseResultMap">
        SELECT * FROM university
        WHERE (#{country} IS NULL OR #{country} = '' OR country = #{country})
          AND (#{search} IS NULL OR #{search} = '' OR name_cn LIKE CONCAT('%', #{search}, '%') OR name_en LIKE CONCAT('%', #{search}, '%'))
        ORDER BY rank ASC
    </select>
</mapper>